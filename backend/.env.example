# SmartPaper API — Variáveis de Ambiente
# Copie este ficheiro para .env e preencha os valores

# ── Base de Dados ──
# Comente ou remova para usar SQLite (desenvolvimento local)
# Descomente para usar PostgreSQL (produção)
#DATABASE_URL=postgresql://usuario:senha@host:5432/smartpaper?sslmode=require

# ── Servidor ──
PORT=3001

# ── CORS ──
# Em produção, coloque o URL do frontend no Vercel
CORS_ORIGIN=http://localhost:5173

# ── JWT ──
# Altere para uma string aleatória e segura em produção
JWT_SECRET=smartpaper_jwt_secret_change_in_production
